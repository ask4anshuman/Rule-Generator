# ──────────────────────────────────────────────────────────────────────────────
# Rule Generator — Environment Variables  (SECRETS ONLY)
# Copy this file to .env and fill in the values for your chosen provider.
# Non-secret settings (model, temperature, etc.) live in config/llm_config.yaml
# ──────────────────────────────────────────────────────────────────────────────

# ── Provider override (optional) ──────────────────────────────────────────────
# Overrides LLM_PROVIDER in config/llm_config.yaml when set.
# One of: openai | azure | anthropic
# LLM_PROVIDER=openai

# ── API key (required for all providers) ──────────────────────────────────────
LLM_API_KEY=...

# ── Azure endpoint (Azure only) ───────────────────────────────────────────────
# LLM_ENDPOINT=https://<your-resource>.openai.azure.com/
